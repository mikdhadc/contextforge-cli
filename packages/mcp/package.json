{
  "name": "@contextforge/mcp",
  "description": "ContextForge MCP server — exposes project context and conventions to AI-powered IDEs via the Model Context Protocol",
  "keywords": ["mcp", "ai", "context", "conventions", "claude-code", "cursor"],
  "license": "MIT",
  "engines": { "node": ">=20" },
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "contextforge-mcp": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --tsconfig tsconfig.build.json",
    "dev": "tsx watch src/bin.ts",
    "test": "vitest --run --reporter=verbose",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contextforge/generator": "workspace:*",
    "@contextforge/scanner": "workspace:*",
    "@contextforge/watcher": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
