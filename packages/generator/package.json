{
  "name": "@contextforge/generator",
  "description": "ContextForge generator — renders and patches .context.md files and writes IDE-specific instruction files",
  "keywords": ["generator", "context", "markdown", "ide", "claude-code", "cursor"],
  "license": "MIT",
  "engines": { "node": ">=20" },
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --tsconfig tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "test": "vitest --run --reporter=verbose",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contextforge/scanner": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0"
  }
}
